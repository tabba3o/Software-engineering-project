@startuml act_enroll_students
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12

skinparam activity {
  BackgroundColor #E8F0FE
  BorderColor #1A56DB
  FontColor #1E293B
  DiamondBackgroundColor #FEF9C3
  DiamondBorderColor #CA8A04
  DiamondFontColor #1E293B
}

skinparam swimlane {
  BorderColor #1A56DB
  BorderThickness 2
  TitleFontSize 13
  TitleFontStyle bold
}

skinparam arrow {
  Color #334155
  FontColor #334155
  FontSize 11
}

skinparam note {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
}

title <b>Activity Diagram – Enroll Students in Courses</b>\nGroup 07 · Learning Management System

|Administrator|
start
:Log In to LMS;
:Navigate to\nEnrollment Management;
:Search Student\n(by name or ID);
:Select Student\nfrom Results;
:Browse Available\nCourse Offerings;
:Select Target Course;

|System|
:Retrieve Student\nAcademic Record\n<i>(University SIS)</i>;
:Check Course\nPrerequisites;

if (Prerequisites\nMet?) then (no)
  :Display Missing\nPrerequisites;

  |Administrator|
  if (Override\nPrerequisites?) then (yes)
    :Log Override\nJustification;
    note right: Must be documented\nper institution policy
  else (no)
    :Cancel Enrollment;
    stop
  endif
endif

|System|
:Check Seat\nAvailability;

if (Seats\nAvailable?) then (no)
  :Display "Course Full"\nMessage;

  |Administrator|
  if (Add to\nWaitlist?) then (yes)
    |System|
    :Add Student\nto Waitlist Queue;
    :Send Waitlist\nNotification to Student\n<i>(Email & Notification Service)</i>;

    |System|
    :Monitor for\nFreed Seats;

    if (Seat Freed?) then (yes)
      :Auto-Enroll\nNext Waitlisted Student;
    else (no)
      stop
    endif
  else (no)
    stop
  endif
endif

|System|
:Enroll Student\nin Course;
:Decrement\nAvailable Seat Count;
:Sync Enrollment Record\nwith University SIS;

fork
  :Send Enrollment\nConfirmation to Student\n<i>(Email & Notification Service)</i>;
fork again
  :Update Instructor's\nCourse Roster;
fork again
  :Log Enrollment\nAction in Audit Trail;
end fork

|Student|
:Receive Confirmation\nEmail;
:Access Course\nDashboard & Materials;

|Instructor|
:View Updated\nCourse Roster;

stop
@enduml
