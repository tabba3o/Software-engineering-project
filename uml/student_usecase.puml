@startuml StudentUseCase
title Composite Use Case Diagram: Student\nLearning Management System

left to right direction

skinparam shadowing false
skinparam defaultFontName SansSerif
skinparam defaultFontSize 13
skinparam usecase {
  BackgroundColor White
  BorderColor #1f77b4
  FontColor Black
}
skinparam actor {
  BorderColor Black
  FontColor Black
}

actor "Student" as S

usecase "View Enrolled Courses"             as UC1
usecase "Access Course Materials"           as UC2
usecase "View Assignment Deadlines"         as UC3
usecase "Submit Assignment"                 as UC4
usecase "Withdraw Submission"               as UC5
usecase "View Assignment Feedback"          as UC6
usecase "View Assignment Grades"            as UC7
usecase "View Course Performance Report"    as UC8
usecase "View Overall Academic Performance" as UC9
usecase "Receive Notifications"             as UC10

S -- UC1
S -- UC2
S -- UC3
S -- UC4
S -- UC5
S -- UC6
S -- UC7
S -- UC8
S -- UC9
S -- UC10

@enduml
